# Google Cloud Project Configuration
project_id = "your-gcp-project-id"
region     = "us-central1"

# Google Drive & Sheets Configuration
drive_root_folder_id = "your-google-drive-folder-id"  # Get from Drive URL
awards_sheet_id      = "your-awards-sheet-id"         # Awards submissions sheet
survey_sheet_id      = "your-survey-sheet-id"         # Survey responses sheet (optional)

# Google Service Account
google_service_account_key_file = "your-api-key-json-filepath"

# Domain Configuration (optional - for custom domain)
domain = "awards.yourcompany.com"  # Leave empty to use default Cloud Run URL

# reCAPTCHA Configuration
recaptcha_site_key   = "your-recaptcha-v3-site-key"
recaptcha_secret_key = "your-recaptcha-v3-secret-key"

# Notification Email (for errors/alerts)
admin_email = "admin@yourcompany.com"

# Drive Owner Email (for folder ownership transfer)
# IMPORTANT: This must be the Google account that owns the Drive folder
# This email will own all created folders and uploaded files
drive_owner_email = "admin@yourcompany.com"

# Resource Configuration
environment = "production"  # or "staging", "dev"

# Storage Configuration
storage_location      = "US"  # or "EU", "ASIA"
storage_class         = "STANDARD"
lifecycle_delete_days = 365  # Delete old submissions after 1 year

# Google Service Account Key (for Sheets/Drive API access)
# Provide the full JSON key file contents as a string
# google_service_account_key = file("/path/to/uc-and-d-sheets-api-key.json")

# Limits
max_pdf_size_mb   = 50
max_photo_size_mb = 20

# SMTP / Email Configuration
# The SMTP password must be stored in Secret Manager under the name `email-password`.
# Create it manually with:
#   gcloud secrets create email-password --replication-policy=automatic
#   echo -n "your-password" | gcloud secrets versions add email-password --data-file=-
smtp_host = "host400.hostmonster.com"
smtp_port = 465                           # 465 for SSL, 587 for STARTTLS
smtp_user = "you@yourcompany.com"
smtp_from = "you@yourcompany.com"         # Optional; defaults to smtp_user
app_url   = "https://awards.yourcompany.com"

